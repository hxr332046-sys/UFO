  "saveMechanism": {
    "method": "flow-control.save(null, null, 'working')",
    "flow": [
      "1. save() → eventBus.$emit('flow-save-basic-info')",
      "2. 子组件回调返回各自form数据",
      "3. operationBusinessDataInfo('tempSave','BasicInfo', mergedData) 组装请求",
      "4. 敏感字段RSA加密 → XHR POST JSON"
    ],
    "knownIssues": {
      "A0002_busiAreaData_encoding": {
        "cause": "busiAreaData被encodeURIComponent(JSON.stringify(...))编码为URL字符串",
        "fix": "拦截XHR.send，将busiAreaData从URL编码字符串解析回JSON对象",
        "alsoFix": "genBusiArea为空时从busiAreaData.param提取name拼接"
      },
      "busineseForm_sync": {
        "cause": "confirm()后busineseForm字段(itemIndustryTypeCode,industryTypeName,genBusiArea)可能未同步",
        "fix": "confirm后手动comp.$set(bf, key, value)"
      }
    }
  },
  "componentMethods": {
    "tne-data-picker": {
      "nativeInteraction": "点击input → 点击.sample-item逐级选择",
      "internalSync": "点击后自动同步selected/inputValue/residenceForm",
      "NOT_RECOMMENDED": "直接设置picker.selected + updateBindData → modelValue不同步 → 验证失败"
    },
    "tne-select-tree": {
      "nativeInteraction": "点击input → 点击.el-tree-node__content选择节点",
      "internalSync": "handleNodeClick自动设置valueId/valueTitle",
      "EXTRA_NEEDED": "需手动$set busineseForm.itemIndustryTypeCode/industryTypeName"
    },
    "tni-business-range": {
      "method": "businese-info.confirm(data)",
      "dataFormat": "必须用searchList原始格式(含id,stateCo,pid,minIndusTypeCode等完整字段)",
      "NOT_RECOMMENDED": "手动构造简化格式 → A0002"
    }
  }
