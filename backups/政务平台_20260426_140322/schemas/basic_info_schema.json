  "saveMechanism": {
    "description": "保存流程说明",
    "steps": [
      "1. flow-control.save(null, null, 'working') 触发保存（working=暂存草稿）",
      "2. eventBus.$emit('flow-save-basic-info', {data:'BasicInfo', sign:'working'})",
      "3. 子组件通过eventBus回调返回各自form数据",
      "4. operationBusinessDataInfo('tempSave','BasicInfo', mergedData) 组装请求",
      "5. 敏感字段RSA加密 → XHR POST JSON body"
    ],
    "saveMethod": "comp.save(null, null, 'working')",
    "apiEndpoint": "operationBusinessDataInfo",
    "encryptedFields": ["entPhone"],
    "knownIssues": {
      "A0002": {
        "description": "服务端异常",
        "possibleCauses": [
          "busiAreaData格式不正确（必须用searchList原始格式）",
          "必填字段未完成（按验证提示逐项完成）",
          "反复调试未刷新页面导致服务端状态异常"
        ],
        "solutions": [
          "刷新页面后重新填写",
          "确保所有验证提示为0后再保存",
          "使用searchList原始格式设置经营范围"
        ]
      }
    }
  },
  "componentMap": {
    "flow-control": {
      "description": "主流程控制组件，包含businessDataInfo(185字段)",
      "keyMethods": ["save(btn,cb,sign)", "handleSteps(step)", "handleStepsNext(step)", "next()"],
      "dataPath": "$data.businessDataInfo"
    },
    "residence-information": {
      "description": "住所/地址组件，包含residenceForm(43字段)",
