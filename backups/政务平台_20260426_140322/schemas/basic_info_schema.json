      "dataPath": "residenceForm",
      "fields": ["distCode", "distCodeName", "provinceCode", "provinceName", "cityCode", "cityName", "fisDistCode", "detAddress", "detBusinessAddress", "isSelectDistCode", "havaAdress", "houseToBus", "normAddFlag"]
    },
    "businese-info": {
      "description": "经营范围组件，包含busineseForm(18字段)",
      "keyMethods": ["confirm(data)", "validateBusinessArea()", "getIndustryList()", "treeSelectChange()", "handleDelBusinessRange()"],
      "dataPath": "busineseForm",
      "fields": ["busiAreaData", "genBusiArea", "busiAreaCode", "busiAreaName", "businessArea", "areaCategory", "secretaryServiceEnt", "xfz"]
    },
