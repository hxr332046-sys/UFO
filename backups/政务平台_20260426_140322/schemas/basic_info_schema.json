    "distCode": {
      "label": "企业住所",
      "index": 21,
      "group": "residence",
      "compType": "tne-data-picker",
      "formModel": "residenceForm",
      "prop": "distCode",
      "required": true,
      "placeholder": "请选择省/市/区/街道",
      "fillMethod": {
        "type": "tne-data-picker",
        "realComponent": "tne-data-picker (class: wherecascader)",
        "keyMethods": ["updateSelected", "updateBindData", "loadAllData", "loadData", "getNodeData", "getTreePath", "clear"],
        "approach1": {
          "description": "tne-data-picker组件方法（推荐）",
          "steps": [
            "1. findComp(vm, 'residence-information', 0) 获取住所组件",
            "2. 遍历子组件找到 tne-data-picker (path: ri>0>0>4>0>1 或递归搜索)",
            "3. 调用 picker.loadAllData() 或 picker.loadData() 加载选项数据",
            "4. 调用 picker.updateSelected({code:'450103', name:'青秀区', ...}) 设置选中值",
            "5. 调用 picker.updateBindData() 同步绑定数据",
            "6. 同时设置 residenceForm: distCode='450103', distCodeName='青秀区', provinceCode='450000', provinceName='广西壮族自治区', cityCode='450100', cityName='南宁市'",
            "7. 触发 ri.distCodeChange() 让组件内部状态同步"
          ]
        },
        "approach2": {
          "description": "DOM点击popover面板（备选）",
          "steps": [
            "1. 点击tne-data-picker的input元素",
            "2. 等待el-popover面板展开（class: tne-data-picker-popover wherecascader）",
            "3. 面板内是树形结构，逐级点击省/市/区",
            "4. 每级点击后等待2秒让子节点懒加载"
          ]
        },
        "notes": "不是标准el-cascader！是自定义tne-data-picker组件。$emit('input')不会触发内部状态同步。必须用组件方法updateSelected/updateBindData或DOM点击popover面板"
      },
      "validation": {"message": "请选择企业住所", "trigger": "change"},
      "cascaderPath": ["450000", "450100", "450103"],
      "cascaderLabels": ["广西壮族自治区", "南宁市", "青秀区"],
      "dependencies": {
        "affects": ["fisDistCode", "address", "detAddress", "生产经营地址", "行业类型选项", "经营范围选项"],
        "note": "住所区域代码影响生产经营地址默认值、行业类型可选范围、经营范围对话框内容"
      }
    },
