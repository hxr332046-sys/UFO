    "itemIndustryTypeCode": {
      "label": "行业类型",
      "index": 30,
      "group": "business",
      "compType": "tne-select-tree",
      "formModel": "businessDataInfo",
      "prop": "itemIndustryTypeCode",
      "required": true,
      "placeholder": "请选择行业类型",
      "fillMethod": {
        "type": "tne-select-tree",
        "realComponent": "tne-select-tree (class: tree-select) 包裹 tne-select(extends el-select) + tne-tree(extends el-tree)",
        "keyMethods": {
          "tne-select-tree": ["handleNodeClick", "chooseNode", "onChange", "filterNode", "clearHandle", "dropdownHandle"],
          "tne-select": ["setSelected", "emitChange", "handleQueryChange"],
          "tne-tree": ["setCurrentKey", "setCurrentNode", "getNode", "filter", "getCheckedNodes"]
        },
        "approach1": {
          "description": "tne-select-tree.chooseNode方式（推荐）",
          "steps": [
            "1. 找到tne-select-tree组件 (path: bi>0>0>0>0>2)",
            "2. 调用 treeComp.dropdownHandle(true) 打开下拉",
            "3. 等待3秒让树节点加载",
            "4. 找到I节点: treeComp.filterNode('信息传输') 或遍历tree store",
            "5. 调用 treeComp.handleNodeClick(nodeData) 点击I节点展开",
            "6. 等待3秒懒加载",
            "7. 调用 treeComp.chooseNode({code:'I65',label:'软件和信息技术服务业'}) 选中",
            "8. treeComp.onChange() 触发变更",
            "9. 验证 tne-select.inputValue 更新"
          ]
        },
        "approach2": {
          "description": "DOM点击方式（备选）",
          "steps": [
            "1. 点击select input，等待下拉面板展开",
            "2. 面板中有tne-tree，找到[I]节点并点击展开箭头",
            "3. 等待3秒懒加载",
            "4. 找到[65]节点点击",
            "5. 关键：点击后必须触发chooseNode/onChange，否则tne-select值不更新"
          ]
        },
        "notes": "树形下拉，选项懒加载！点击树节点后tne-select-tree内部会调用chooseNode→onChange→tne-select.setSelected。如果直接点击DOM，tne-select可能不更新，需要额外触发"
      },
      "validation": {"message": "请选择行业类型", "trigger": "change"},
      "treeStructure": {
        "root": ["A农/林/牧/渔", "B采矿业", "...", "I信息传输/软件/IT", "...", "T国际组织"],
        "targetPath": "I → 65 → 软件和信息技术服务业"
      },
      "sampleValue": "I65",
      "dependencies": {
        "requires": ["distCode"],
        "affects": ["busiAreaCode", "busiAreaData", "经营范围选项"],
        "note": "行业类型决定经营范围的可选范围"
      }
    },
    "busiAreaData": {
      "label": "经营范围（许可经营项目）",
      "index": 32,
      "group": "business",
      "compType": "button-dialog",
      "formModel": "busineseForm",
      "prop": "busiAreaData",
      "required": true,
      "fillMethod": {
        "type": "businese-info-confirm",
        "approach1": {
          "description": "DOM交互方式（推荐，最接近用户操作）",
          "steps": [
            "1. 点击'添加规范经营用语'按钮",
            "2. 等待tni-dialog对话框打开（注意：如果住所未选，对话框可能显示'请选择所在省/市/区/街道'）",
            "3. 在对话框搜索框输入关键词（如'软件开发'）",
            "4. 等待搜索结果加载",
            "5. 勾选需要的经营范围项",
            "6. 点击确定按钮",
            "7. businese-info.confirm()自动被调用"
          ]
        },
        "approach2": {
          "description": "直接调用confirm方法（备选）",
          "steps": [
            "1. findComp(vm, 'businese-info', 0)",
            "2. comp.confirm({busiAreaData: [...searchList格式items], genBusiArea: '名称;名称', busiAreaCode: 'I65', busiAreaName: '名称,名称'})",
            "3. 验证 comp.busineseForm.busiAreaData.length > 0"
          ],
          "jsTemplate": "comp.confirm({busiAreaData:[{id:'I3006',stateCo:'3',name:'软件开发',pid:'65',minIndusTypeCode:'6511;6512;6513',midIndusTypeCode:'651;651;651',isMainIndustry:'1',category:'I',indusTypeCode:'6511;6512;6513',indusTypeName:'软件开发'},...], genBusiArea:'软件开发;信息技术咨询服务', busiAreaCode:'I65', busiAreaName:'软件开发,信息技术咨询服务'})"
        },
        "notes": [
          "必须使用searchList原始格式（含id/stateCo/pid/minIndusTypeCode等完整字段）",
          "手动构造的简化格式{name,code,industryCode,isMain,sort}会导致服务端A0002异常",
          "genBusiArea必须是纯文本字符串如'软件开发;信息技术咨询服务'，不能是数组",
          "经营范围对话框依赖住所区域代码，住所未填时对话框内容为空"
        ]
      },
      "validation": {"message": "请填写经营范围", "trigger": "blur"},
      "dataFormat": {
        "correctFormat": {
          "description": "searchList原始格式（从tni-business-range组件获取）",
          "sampleItem": {
            "id": "I3006",
            "stateCo": "1",
            "name": "软件开发",
            "pid": "65",
            "minIndusTypeCode": "6511;6512;6513",
            "midIndusTypeCode": "651;651;651",
            "isMainIndustry": "0",
            "category": "I",
            "indusTypeCode": "6511;6512;6513",
            "indusTypeName": "软件开发"
          },
          "stateCo_values": {"3": "主营经营项目", "1": "一般经营项目"},
          "isMainIndustry_values": {"1": "主营行业", "0": "非主营"}
        },
        "wrongFormat": {
          "description": "手动构造的简化格式（会导致A0002）",
          "sampleItem": {"name": "软件开发", "code": "I3006", "industryCode": "I65", "isMain": "1", "sort": 1}
        }
      },
      "dependencies": {
        "requires": ["distCode", "itemIndustryTypeCode"],
        "note": "经营范围依赖住所区域和行业类型，必须先完成这两项"
      }
    },
