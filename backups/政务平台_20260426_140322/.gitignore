# Python 缓存
__pycache__/
*.pyc
*.pyo

# 虚拟环境
.venv*/

# 运行时敏感文件（含 token / cookies）
packet_lab/out/runtime_auth_headers.json
packet_lab/out/http_session_cookies.pkl
packet_lab/out/login_qrcode.png
data/tokens.json

# 凭据
config/credentials.json

# IDE
.vscode/
.idea/
*.swp

# 日志
*.log

# 归档（旧文件，不推送到远程）
_archive/

# 大文件（超 GitHub 100MB 限制）
*.sqlite
*.sqlite3

# mitm 抓包流量（含 RSA 加密身份证、token 等敏感数据）
dashboard/data/records/mitm_*.jsonl

# 下载的页面静态资源（core_assets 下 JS/CSS 快照）
dashboard/data/records/core_assets/

# 临时 debug 文件（下划线前缀约定）
dashboard/data/records/_*.json
dashboard/data/records/_*.txt
system/_*.py

# 系统文件
Thumbs.db
.DS_Store
