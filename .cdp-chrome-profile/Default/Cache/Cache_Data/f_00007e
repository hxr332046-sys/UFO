",choseList:JSON.stringify(l.level),show:"Y",disabled:!1,defaultValue:"",hasLabel:"Y"},{code:"decorativefabric",label:"装饰织物",type:"radio",must:"",fieldLength:"",placeholder:"",readonly:"",unit:"",linkage:[],checkCondition:"",choseList:JSON.stringify(l.level),show:"Y",disabled:!1,defaultValue:"",hasLabel:"Y"},{code:"other",label:"其他",type:"radio",must:"",fieldLength:"",placeholder:"",readonly:"",unit:"",linkage:[],checkCondition:"",choseList:JSON.stringify(l.level),show:"Y",disabled:!1,defaultValue:"",hasLabel:"Y"}]},{name:"其他",code:"",prop:"interiorDecoration",stuffType:"",labelWidth:"190px",fieldcfgList:[{code:"otherusefire",label:"其他需要说明的情况",type:"textarea",must:"1",fieldLength:"",placeholder:"填写场所使用多栋建筑等情况，包括每栋建筑的名称、建筑面积、建筑层数和建筑高度。",readonly:"",unit:"",linkage:[],checkCondition:"",show:"Y",disabled:!1,defaultValue:"",hasLabel:"Y"}]}]},o=function(){return{title:"消防安全告知事项",html:'     <div style="text-align: center">      <h1>消防安全告知事项</h1>      <div style="text-align: left; line-height: 1.5">        <p><span style="visibility: hidden">一二</span>根据《中华人民共和国消防法》，现将公众聚集场所投入使用、营业前消防安全检查实行告知承诺管理有关事项告知如下：</p>        <h3><span style="visibility: hidden">一二</span> 一、法律依据</h3>        <p><span style="visibility: hidden">一二</span>《中华人民共和国消防法》第十五条规定。公众聚集场所投入使用、营业前消防安全检查实行告知承诺管理。公众聚集场所在投入使用、营业前，建设单位或者使用单位应当向场所所在地的县级以上地方人民政府消防救援机构申请消防安全检查，作出符合消防安全标准的承诺，提交规定的材料，并对其承诺和材料的真实性负责。</p>        <h3><span style="visibility: hidden">一二</span>二、行政许可范围</h3>        <p><span style="visibility: hidden">一二</span>（一）宾馆、饭店、商场、集贸市场、客运车站候车室、客运码头候船厅、民用机场航站楼、体育场馆、会堂等；</p>        <p><span style="visibility: hidden">一二</span>（二）公共娱乐场所：影剧院、录像厅、礼堂等演出、放映场所；舞厅、卡拉OK厅等歌舞娱乐场所；具有娱乐功能的夜总会、音乐茶座和餐饮场所；游艺、游乐场所；保龄球馆、旱冰场、桑拿浴室等营业性健身、休闲场所。</p>        <h3><span style="visibility: hidden">一二</span> 三、基本要求 </h3>        <p><span style="visibility: hidden">一二</span>开办公众聚集场所应当符合法律法规和消防技术标准要求。<br /><span style="visibility: hidden">一二</span>娱乐场所、互联网上网服务营业场所的设置地点还应当符合《娱乐场所管理条例》、《互联网上网服务营业场所管理条例》。</p>        <h3><span style="visibility: hidden">一二</span>四、申请材料</h3>        <p><span style="visibility: hidden">一二</span>公众聚集场所的建设单位或者使用单位通过消防业务受理窗口或者消防在线政务服务平台提交以下材料：<br />          <span style="visibility: hidden">一二</span> 1.公众聚集场所投入使用、营业消防安全告知承诺书；<br />          <span style="visibility: hidden">一二</span>2.营业执照； <br />          <span style="visibility: hidden">一二</span>3.消防安全制度、灭火和应急疏散预案； <br />          <span style="visibility: hidden">一二</span> 4.场所平面布置图、场所消防设施平面图；<br />          <span style="visibility: hidden">一二</span>5.法律、行政法规规定的其他材料。 <br />          <span style="visibility: hidden">一二</span>第1、2项材料通过消防在线政务服务平台或者消防业务受理窗口提交；其他材料可以在消防救援机构现场核查时提交。</p>        <h3><span style="visibility: hidden">一二</span> 五、办理时限 </h3>        <p><span style="visibility: hidden">一二</span>对到消防业务受理窗口提出申请的，当场作出决定；对通过消防在线政务服务平台提出申请的，自收到申请之日起一个工作日内办结。</p>        <h3><span style="visibility: hidden">一二</span>六、法律责任</h3>        <p><span style="visibility: hidden">一二</span>经核查发现场所使用、营业情况与承诺内容不符的，责令停止使用、停产停业，并处三万元以上三十万元以下罚款；经责令限期改正，逾期不整改或者整改后仍达不到要求的，依法撤销相应许可。</p>      </div>    </div>'}},a=function(){return{title:"办件须知",html:'   <div style="text-align: center">      <h1>消防安全承诺</h1>      <div style="text-align: left; line-height: 1.5">        <p>          <span style="visibility: hidden">一二</span>现就申请公众聚集场所投入使用、营业作出下列消防安全承诺：<br />          <span style="visibility: hidden">一二</span> 一、已认真学习消防法律法规，对公众聚集场所投入使用、营业前消防安全检查告知事项的全部内容已经知晓和全面理解。<br />          <span style="visibility: hidden">一二</span> 二、已符合《公众聚集场所消防安全要求》，场所所在建筑为合法建筑，场所满足公众聚集场所投入使用、营业的各项消防安全条件。 <br />          <span style="visibility: hidden">一二</span>三、在使用、营业过程中遵守消防法律法规和消防技术标准，确保消防安全。 <br />          <span style="visibility: hidden">一二</span>四、所填写的信息真实、准确。<br />          <span style="visibility: hidden">一二</span>五、及时提交相关材料，并确保真实、合法、有效。<br />          <span style="visibility: hidden">一二</span>以上承诺是申请人的真实意思表示。如有违反承诺的行为，愿意承担相应的法律责任。        </p>      </div>    </div>'}}},"436c":function(e,l,t){"use strict";t.r(l),t.d(l,"getOptions",(function(){return i})),t("e9c4");var