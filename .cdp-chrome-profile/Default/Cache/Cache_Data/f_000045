//获取浏览器地址栏参数
function getQueryString(name){
	var  url = location.href;
	var n1 = url.length;
	var n2 = url.indexOf("?");
	var arr = url.substr(n2 + 1, n1 - n2).split('&');
	for(var i = 0; i < arr.length; i++){
		if(name == arr[i].split('=')[0]){
			return decodeURIComponent(arr[i].split('=')[1])
		}
	}
}


