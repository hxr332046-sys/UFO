	})
	// 初始化验证码  嵌入式
	$(idName).slideVerify({
		baseUrl:'/am',
		mode:'fixed',
		imgSize : {       //图片的大小对象
	     	width: imgWidth,
	     	height: imgHeight,
		},
		barSize:{
			width: imgWidth,
			height: barHeight,
		},
	   success: function(params) { //成功的回调
			// 返回的二次验证参数 合并到验证通过之后的逻辑 参数中回传服务器
			sliderResult = true;
			$(idName).hide().siblings(".slider_success").show();
