//提示信息
function errTipMsg(type,text){
	$(".err_text").text("");
	if(text){
		if(type == "success"){
			$(".err_text").text(text).siblings().attr("src","../img/success1.png").parents(".err_tip").addClass("success_tip").show();
			setTimeout(function(){$(".err_tip").hide();},2000);
		}else{
			$(".err_text").text(text).siblings().attr("src","../img/error.png").parents(".err_tip").removeClass("success_tip").show();
			setTimeout(function(){$(".err_tip").hide();},2000);
		}
	}else{
		$(".err_text").text("系统错误，请联系管理员").siblings().attr("src","../img/error.png").parents(".err_tip").removeClass("success_tip").show();
		setTimeout(function(){$(".err_tip").hide();},2000);
	}
}

//ajax
function ajaxFun(url,type,async,contentType,data,callback){
	if(!url.includes("checkQrCode")){
		getRandom();

	}
	$.ajax({
	   url: url+'?time='+new Date().getTime(),
		type: type ? type : "post",
		async: async ? true : false,
	   contentType: contentType ? contentType : 'application/x-www-form-urlencoded',
	   dataType:"json",
	   data:data,
	   success:function(res) {
	      callback(res);
	   },
	   error:function(err){
			errTipMsg("error",err.message);
	   }
	})
}


//获取二维码
var codeInterval = null;
var pullCount = 0;
var g_hand_timer = null;
function getQRCode(type){
	clearInterval(codeInterval);
	$(".reload").hide();
	$("#QRcode_img").empty();
	ajaxFun("../qrCode/getQrcode",null,false,null,{
		userType:type,
	},function(res){
		$("#QRcode_img").attr("src", res.data.qrCode)
		checkQRCodeResult(res.data.sessionId, type);
	})
}
//轮询扫码结果
function checkQRCodeResult(text, type){
   codeInterval = setInterval(function(){
		if(pullCount >= 12){
			clearInterval(codeInterval);
			pullCount = 0;
			$("#gxQrcode").show();
			return false;
		}
		pullCount += 1;
		ajaxFun("../qrCode/checkQrCode",null,true,null,{
			random: text
		},function(res){
			if(res.status == 'success'){
				clearInterval(codeInterval);
				switch (res.data) {
					case "1":
						loginByQRCode(text, type);
						break;
					case "3":
						errTipMsg("error",'用户信息不存在，请注册后再登录');
						break;
					default:
						errTipMsg("error",'登录失败，请刷新页面重新扫描');
				}
			}
		})
   },5000)
}


